LANDLORD_SIRET=000 000 000 00000
LANDLORD_RCS=000 000 000 R.C.S. Ville
LANDLORD_TVA=FRXXXXXXXXX
LANDLORD_REPRESENTATIVE=Prénom NOM, gérant
LANDLORD_CITY=Ville

# Property
PROPERTY_ADDRESS=Adresse du bien loué
